{
    "name": "@medhub/server",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/server/src/index.js",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "prisma:migrate": "prisma migrate dev",
        "prisma:seed": "tsx prisma/seed.ts",
        "check:connections": "tsx src/scripts/checkConnections.ts"
    },
    "dependencies": {
        "@medhub/shared": "workspace:*",
        "@prisma/client": "^5.17.0",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.12.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^17.4.2",
        "express": "^4.19.2",
        "express-rate-limit": "^7.4.0",
        "express-slow-down": "^2.0.3",
        "helmet": "^7.1.0",
        "hibp": "^13.0.0",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "node-fetch": "^3.3.2",
        "speakeasy": "^2.0.0",
        "uuid": "^10.0.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^22.0.0",
        "@types/speakeasy": "^2.0.10",
        "@types/uuid": "^10.0.0",
        "prisma": "^5.17.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.4",
        "vitest": "^2.0.5"
    }
}