# ═══════════════════════════════════════════════════════════
# MEDHUB — Environment Variables
# Copy this file to .env and fill in your values
# ⚠ NEVER commit .env to git
# ═══════════════════════════════════════════════════════════

# ─── Database — Supabase ────────────────────────────────────
# Sign up at: supabase.com → New Project → Settings → Database
# ⚠ Use the DIRECT connection string — NOT the pooler URL
# Pooler (PgBouncer) breaks SET LOCAL for RLS and silently destroys tenant isolation
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ─── Redis — Upstash ────────────────────────────────────────
# Sign up at: upstash.com → Create Database → "Redis Protocol" section
# ⚠ Use rediss:// (Redis protocol) NOT the REST API URL
# BullMQ uses Lua scripting (EVALSHA) — REST API does not support this
REDIS_URL=rediss://:[password]@[region].upstash.io:6379

# ─── CouchDB — IBM Cloudant ─────────────────────────────────
# Sign up at: ibm.com/cloudant → Service Credentials
# Before running Step 9: test _users creation (see README)
COUCHDB_URL=https://[username].cloudantnosqldb.appdomain.cloud
COUCHDB_ADMIN_USER=
COUCHDB_ADMIN_PASS=

# ─── Auth ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ─── HMAC Signing ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUDIT_HMAC_SECRET=
SYNC_HMAC_SECRET=

# ─── MFA ────────────────────────────────────────────────────
MFA_ISSUER=MEDHUB

# ─── App ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
NODE_ENV=development
PORT=3000

# ─── External APIs ──────────────────────────────────────────
# HaveIBeenPwned v3 API key: haveibeenpwned.com/API/Key
HIBP_API_KEY=

# ─── Encryption Keys ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠ Keep these three keys SEPARATE — compromise of one must not endanger the others
COUCHDB_CREDENTIAL_ENCRYPTION_KEY=   # Encrypts CouchDB passwords stored in Device table
LSK_ENCRYPTION_KEY=                   # Encrypts Local Storage Keys (per-device DB encryption)
MFA_ENCRYPTION_KEY=                   # Encrypts MFA TOTP secrets at rest
